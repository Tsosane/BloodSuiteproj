# Frontend environment variables
REACT_APP_API_URL=http://localhost:5000/api

# Add your real Google Maps JavaScript API key here to enable live maps and turn-by-turn directions.
REACT_APP_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
REACT_APP_DEFAULT_MAP_CENTER_LAT=-29.6100
REACT_APP_DEFAULT_MAP_CENTER_LNG=28.2336
